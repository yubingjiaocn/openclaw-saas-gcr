# ============================================
# OpenClaw SaaS Platform Configuration (CN)
# ============================================
# Copy this file to .env and fill in values before deploying.
# Usage: cp .env.example .env && vim .env && ./scripts/deploy.sh

# --- Required (must set before first deploy) ---
ADMIN_EMAIL=admin@openclaw.ai
ADMIN_PASSWORD=        # ⚠️ MUST CHANGE: set a strong password
JWT_SECRET=            # ⚠️ MUST CHANGE: run `openssl rand -hex 32` to generate

# --- AWS China Region ---
AWS_REGION=cn-northwest-1
AWS_PARTITION=aws-cn
AWS_ACCOUNT_ID=735091234506

# --- Platform Settings ---
K8S_IN_CLUSTER=true
LOG_LEVEL=INFO
AVAILABLE_CHANNELS=feishu

# --- Agent Image (CN custom image with pre-installed tools) ---
DEFAULT_AGENT_IMAGE=735091234506.dkr.ecr.cn-northwest-1.amazonaws.com.cn/openclaw-custom-cn
DEFAULT_AGENT_IMAGE_TAG=latest

# --- Metrics & Billing ---
METRICS_EXPORTER_REPO=openclaw-saas-metrics-exporter
METRICS_EXPORTER_TAG=v0.3.0     # auto-read from platform/metrics-exporter/VERSION if unset

# --- Auto-populated by deploy.sh (DO NOT set manually) ---
# DATABASE_URL=       (from CDK RDS output)
# SQS_QUEUE_URL=      (from CDK SQS output)
# ECR_REGISTRY=       (from CDK ECR output)
