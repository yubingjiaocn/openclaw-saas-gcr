# ============================================
# OpenClaw SaaS Platform Configuration
# ============================================
# Copy this file to .env and fill in values before deploying.
# Usage: cp .env.example .env && vim .env && ./scripts/deploy.sh

# --- Required (must set before first deploy) ---
ADMIN_EMAIL=admin@openclaw.ai
ADMIN_PASSWORD=        # ⚠️ MUST CHANGE: set a strong password
JWT_SECRET=            # ⚠️ MUST CHANGE: run `openssl rand -hex 32` to generate

# --- AWS Region (auto-detected from CDK, override if needed) ---
AWS_REGION=us-west-2
AWS_PARTITION=aws
AWS_ACCOUNT_ID=956045422469

# --- Platform Settings ---
K8S_IN_CLUSTER=true
LOG_LEVEL=INFO
AVAILABLE_CHANNELS=          # empty = all channels enabled, or comma-separated: feishu,slack

# --- Agent Image (leave empty to use operator default ghcr.io/openclaw/openclaw) ---
DEFAULT_AGENT_IMAGE=
DEFAULT_AGENT_IMAGE_TAG=latest

# --- Metrics & Billing ---
METRICS_EXPORTER_REPO=openclaw-metrics-exporter
METRICS_EXPORTER_TAG=v0.1.0     # auto-read from platform/metrics-exporter/VERSION if unset

# --- Auto-populated by deploy.sh (DO NOT set manually) ---
# DATABASE_URL=       (from CDK RDS output)
# SQS_QUEUE_URL=      (from CDK SQS output)
# ECR_REGISTRY=       (from CDK ECR output)
