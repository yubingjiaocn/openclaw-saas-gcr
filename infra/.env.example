# ============================================
# OpenClaw SaaS Platform Configuration
# ============================================
# Copy the environment-specific template to .env before deploying:
#   Global: cp .env.global .env
#   China:  cp .env.cn .env
#
# Then fill in credentials and run: ./scripts/deploy.sh
#
# See .env.global and .env.cn for pre-filled environment templates.
# All values below are REQUIRED unless marked optional.

# --- Credentials ---
ADMIN_EMAIL=admin@openclaw.ai
ADMIN_PASSWORD=                # ⚠️ REQUIRED
JWT_SECRET=                    # ⚠️ REQUIRED: openssl rand -hex 32

# --- AWS ---
AWS_REGION=us-west-2           # us-west-2 (Global) or cn-northwest-1 (China)
AWS_PARTITION=aws              # aws (Global) or aws-cn (China)
AWS_ACCOUNT_ID=                # ⚠️ REQUIRED

# --- Platform ---
K8S_IN_CLUSTER=true
LOG_LEVEL=INFO
AVAILABLE_CHANNELS=            # optional: empty=all, or comma-separated: feishu,slack

# --- Agent Image ---
DEFAULT_AGENT_IMAGE=           # optional: empty=operator default
DEFAULT_AGENT_IMAGE_TAG=latest

# --- Metrics & Billing ---
METRICS_EXPORTER_REPO=openclaw-saas-metrics-exporter
METRICS_EXPORTER_TAG=v0.3.0

# --- Platform API Image ---
PLATFORM_VERSION=v0.9.55       # update when deploying new platform version

# --- Auto-populated by deploy.sh (DO NOT set manually) ---
# DATABASE_URL=       (from CDK RDS output)
# SQS_QUEUE_URL=      (from CDK SQS output)
# ECR_REGISTRY=       (from CDK ECR output)
