# OpenClaw SaaS CN Configuration
# Copy to .env and fill in values

# AWS Configuration
AWS_REGION=cn-northwest-1
AWS_ACCOUNT_ID=735091234506
AWS_PARTITION=aws-cn

# Admin Configuration (REQUIRED)
ADMIN_EMAIL=
ADMIN_PASSWORD=
JWT_SECRET=

# Domain Configuration (optional, for ALB ingress)
DOMAIN_NAME=
ACM_CERT_ARN=

# Platform Version (auto-read from VERSION files if not set)
# PLATFORM_VERSION=
# METRICS_EXPORTER_TAG=

# Custom Agent Image (CN uses custom image with pre-installed tools)
# DEFAULT_AGENT_IMAGE=
# DEFAULT_AGENT_IMAGE_TAG=latest

# ECR Registry (auto-populated from CDK output if not set)
# ECR_REGISTRY=735091234506.dkr.ecr.cn-northwest-1.amazonaws.com.cn
